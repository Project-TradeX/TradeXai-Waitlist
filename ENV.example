# =========================================================================
# TradeX Pre-Launch Landing Page Environment Variables Template
# Copy this file to '.env.local' and populate with your production keys
# =========================================================================

# 1. Neon Serverless PostgreSQL Database Connection
# Format: postgresql://[user]:[password]@[neon-host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://username:password@ep-glowing-glow-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# 2. Resend Email API Integration (Newsletter & Notifications)
# Get your API key from https://resend.com
RESEND_API_KEY="re_123456789_abcdefghijklmnopqrstuvwxyz"

# 3. PostHog Product Analytics
# Get your public API key and host from https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY="phc_abcdefghijklmnopqrstuvwxyz1234567890"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# 4. App Configuration (For Referral Link Generation)
# Locally: http://localhost:3000
# Production: https://tradex.ai
NEXT_PUBLIC_APP_URL="http://localhost:3000"
